# ── OpenRouter ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://github.com/InnovationCentralPerth/meraki-agentic-iot-triage-openrouter

# ── OpenRouter model IDs (defaults shown — override as needed) ──────────
MODEL_ANALYST=openai/gpt-oss-120b:free
MODEL_COMPOSER=openai/gpt-oss-20b:free
MODEL_ADVISOR=qwen/qwen3-next-80b-a3b-instruct:free
MODEL_FALLBACK=google/gemma-4-31b:free

# ── Local MCP stub (Slack alerts — runs on same host) ───────────────────
LOCAL_MCP_URL=http://localhost:8889/mcp

# ── Slack ────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=your-alerts-channel

# ── Cisco Meraki MT10 (leave MERAKI_API_KEY blank to use simulator) ──────
MERAKI_API_KEY=
MERAKI_MT10_MAC=xx:xx:xx:xx:xx:xx
MERAKI_BASE_URL=https://api.meraki.com/api/v1

# ── Alert thresholds ─────────────────────────────────────────────────────
TEMP_HIGH_C=30.0
TEMP_LOW_C=15.0
HUMIDITY_HIGH_PCT=70.0
HUMIDITY_LOW_PCT=30.0
CO2_HIGH_PPM=1200.0

# ── App settings ─────────────────────────────────────────────────────────
TRIAGE_INTERVAL_S=300
CHAOS_FLAGS=               # leave empty — use dashboard buttons only
